# Skopiuj ten plik jako .env.local i uzupelnij wartosci

# === Supabase ===
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role key (Settings -> API -> service_role) — TYLKO server-side! Uzywany w webhooks.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# === Anthropic Claude (do generowania kodu) ===
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# === OpenAI (Whisper, embeddings) ===
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# === Stripe ===
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs (po stworzeniu produktow w Dashboard):
STRIPE_PRICE_PACK_1000=price_...
STRIPE_PRICE_PACK_5000=price_...
STRIPE_PRICE_PACK_15000=price_...
STRIPE_PRICE_SUB_PRO=price_...
STRIPE_PRICE_SUB_TEAM=price_...

# === Vercel API (custom domains) ===
# https://vercel.com/account/tokens
VERCEL_TOKEN=...
VERCEL_PROJECT_ID=prj_...
VERCEL_TEAM_ID=team_...

# === GitHub OAuth (push to repo) ===
# Konfiguracja w Supabase Dashboard -> Authentication -> Providers -> GitHub
# Tu nic dodatkowego nie jest potrzebne.

# === URL aplikacji ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Domena publikowanych projektow (opcjonalna).
# Jezeli ustawiona, opublikowane strony beda dostepne pod {slug}.{domena}.
NEXT_PUBLIC_PUBLISH_DOMAIN=localhost:3000

# Link do partnera oferujacego rejestracje domen.
NEXT_PUBLIC_DOMAIN_PARTNER_URL=https://zenbox.pl/

# Produkcja (przyklad):
# NEXT_PUBLIC_APP_URL=https://wybitnastrona.pl
# NEXT_PUBLIC_ROOT_DOMAIN=wybitnastrona.pl
# NEXT_PUBLIC_PUBLISH_DOMAIN=wybitny.website
